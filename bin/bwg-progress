#!/usr/bin/env python3
"""Live progress bar for a bin/bwg episode/render run.

Tails the render log (default: newest tmp/bwg-*-live-run.log) and prints:
  - Stage (pull / unzip / build sync maps / grammar / render seg X/Y / verify / share)
  - Progress bar + %  + ETA (measured seg-rate, smoothed)
  - Elapsed

Usage:
  bin/bwg-progress                       # auto-pick newest tmp/bwg-*.log
  bin/bwg-progress --log <path>
  bin/bwg-progress --json share/bwg/progress.json   # legacy HTML dashboard
  bin/bwg-progress --task-id bwg-render-566-<ts>    # write share/tasks/<id>/progress.json
                                                    # (auto session/message from env)
"""
import sys, os, re, time, json, glob, argparse
from datetime import datetime

WS = os.path.expanduser("~/.openclaw/workspace")

def iso_now():
    return datetime.now().astimezone().isoformat(timespec="seconds")

def newest_log():
    logs = sorted(glob.glob(f"{WS}/tmp/bwg-*-live-run.log"), key=os.path.getmtime)
    return logs[-1] if logs else None

def hms(sec):
    if sec is None or sec < 0 or sec != sec: return "--:--"
    sec = int(sec)
    h, m, s = sec // 3600, (sec % 3600) // 60, sec % 60
    return f"{h}:{m:02d}:{s:02d}" if h else f"{m}:{s:02d}"

def bar(pct, w=32):
    fill = int(round(w * pct / 100))
    return "█" * fill + "░" * (w - fill)

STAGE_PATTERNS = [
    (re.compile(r"^\[1/3\] export job"),      "wistia: mint export"),
    (re.compile(r"^\[2/3\] poll .*STARTED"),  "wistia: export starting"),
    (re.compile(r"^\[2/3\] poll .*FINISHED"), "wistia: export ready"),
    (re.compile(r"^\[3/3\] downloading zip"), "download feed bundle"),
    (re.compile(r"^Archive:.*_feeds\.zip"),   "unzip feed bundle"),
    (re.compile(r"^\[ep\] building video sync"), "sync: building video maps"),
    (re.compile(r"^\[ep\] composite="),       "grammar: shot decisions"),
    (re.compile(r"^two-shot sources"),        "grammar: two-shot layout"),
    (re.compile(r"^\s+seg 0/"),               "render: encode segments"),
    (re.compile(r"^DYNDONE"),                 "render: concat master"),
    (re.compile(r"^\[verify"),                "verify: lip-sync gate"),
    (re.compile(r"PASS"),                     "verify: PASS"),
    (re.compile(r"FAIL"),                     "verify: FAIL"),
    (re.compile(r":8011/"),                   "share: published"),
]

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--log", default=None)
    ap.add_argument("--json", default=None, help="also write progress.json for legacy HTML dashboard")
    ap.add_argument("--task-id", default=None,
                    help="also write share/tasks/<id>/progress.json in the workspace task schema")
    ap.add_argument("--task-label", default="BwG render",
                    help="human label for the task row")
    ap.add_argument("--task-kind", default="render")
    ap.add_argument("--interval", type=float, default=1.0)
    ap.add_argument("--wait", type=float, default=0.0,
                    help="wait up to N seconds for the log file to appear (for embedded launches)")
    args = ap.parse_args()

    task_dir = None
    if args.task_id:
        task_dir = f"{WS}/share/tasks/{args.task_id}"
        os.makedirs(task_dir, exist_ok=True)
    session_key = os.environ.get("OPENCLAW_MCP_SESSION_KEY") or None
    message_id  = os.environ.get("OPENCLAW_MCP_CURRENT_MESSAGE_ID") or None
    started_iso = iso_now()
    # Stall detection: if the log file's mtime hasn't advanced in this many
    # seconds while status is still "running", we mark the task as failed.
    # Renders that print every 50 shots at ~1.8s/shot naturally pause up to
    # ~90s between milestones, so a generous ceiling. Bumped for downloads
    # too (curl updates constantly; if it stalls > 3 min, the writer is dead).
    STALL_TIMEOUT_SEC = 300
    stalled = False
    stall_reason = None

    log = args.log or newest_log()
    wait_deadline = time.time() + args.wait
    while (not log or not os.path.exists(log)) and time.time() < wait_deadline:
        time.sleep(0.5)
        log = args.log or newest_log()
    if not log or not os.path.exists(log):
        print(f"no log found (try --log <path>) — checked {WS}/tmp/bwg-*-live-run.log", file=sys.stderr)
        sys.exit(2)

    print(f"tailing {log}\n")
    stage = "starting…"
    seg_cur, seg_tot = 0, 0
    per_seg = 1.8            # smoothed seconds/shot
    last_seg_t = None
    last_seg_n = None
    # Catchup mode: while replaying a pre-existing log, don't let per_seg
    # collapse to ~0. Only trust measurements once we're tailing live.
    caught_up = False
    started = os.path.getmtime(log)
    finished = False
    share_url = None
    fh = open(log, "r", errors="replace")

    seg_re = re.compile(r"^\s*seg (\d+)/(\d+)")
    url_re = re.compile(r"(https?://\S+:8011/\S+)")

    while True:
        chunk = fh.read()
        if chunk:
            # split on both \n and \r so we catch curl's \r-updates
            for line in chunk.replace("\r", "\n").split("\n"):
                if not line.strip(): continue
                for pat, label in STAGE_PATTERNS:
                    if pat.search(line):
                        stage = label
                        break
                m = seg_re.match(line)
                if m:
                    n, tot = int(m.group(1)), int(m.group(2))
                    if seg_tot == 0: seg_tot = tot
                    # Only trust per-seg measurement once we've caught up to live —
                    # otherwise replaying 5 milestones from history collapses per_seg to ~0.
                    if caught_up and last_seg_n is not None and n > last_seg_n and last_seg_t:
                        measured = (time.time() - last_seg_t) / (n - last_seg_n)
                        if measured > 0.05:
                            per_seg = 0.7 * measured + 0.3 * per_seg
                    seg_cur, last_seg_n, last_seg_t = n, n, time.time()
                u = url_re.search(line)
                if u: share_url = u.group(1)
                if "DYNDONE" in line: finished = True
        else:
            caught_up = True

        elapsed = time.time() - started
        if seg_tot:
            # Interpolate between milestones — render_ep.py only emits every 50 shots.
            if caught_up and last_seg_t and seg_cur < seg_tot:
                interp = min(seg_tot, last_seg_n + (time.time() - last_seg_t) / per_seg)
            else:
                interp = seg_cur
            pct = 100.0 * interp / seg_tot
            remaining = max(0, seg_tot - interp) * per_seg
            seg_display = int(interp)
        else:
            pct = 0.0
            remaining = None
            seg_display = seg_cur

        line = f"\r{stage:<28s} {bar(pct)} {pct:5.1f}%  seg {seg_display:>4}/{seg_tot or '?':<4}  eta {hms(remaining):>7}  elapsed {hms(elapsed):>7}   "
        sys.stdout.write(line)
        sys.stdout.flush()

        # Stall detection — the render (or any wrapped writer) can die silently
        # (shutil-shadow class of bugs, oom kills, PTY teardowns). If the log
        # hasn't been touched in a while and we still think we're running,
        # surface it as failed so Gary and Frank both see the failure.
        try:
            log_age = time.time() - os.path.getmtime(log)
        except OSError:
            log_age = 0
        if not share_url and not finished and log_age > STALL_TIMEOUT_SEC:
            stalled = True
            stall_reason = f"log stalled: no output for {int(log_age)}s (writer likely died)"

        if stalled:
            status = "failed"
        elif share_url or (finished and pct >= 99):
            status = "done"
        else:
            status = "running"

        if args.json:
            os.makedirs(os.path.dirname(args.json), exist_ok=True)
            json.dump({
                "status": status,
                "pct": round(pct, 1),
                "detail": stage,
                "segText": f"{seg_cur:,} / {seg_tot:,}" if seg_tot else "—",
                "elapsed": round(elapsed, 1),
                "eta": None if remaining is None else round(remaining),
                "ago": "just now",
                "error": None,
                "masterReady": bool(share_url),
                "shareUrl": share_url,
            }, open(args.json, "w"))

        if task_dir:
            path = f"{task_dir}/progress.json"
            tmp  = f"{path}.tmp"
            payload = {
                "id":         args.task_id,
                "label":      args.task_label,
                "kind":       args.task_kind,
                "status":     status,
                "pct":        round(pct, 1),
                "detail":     stage,
                "segText":    f"{seg_display:,} / {seg_tot:,}" if seg_tot else None,
                "elapsed":    round(elapsed, 1),
                "eta":        None if remaining is None else round(remaining),
                "url":        share_url,
                "error":      stall_reason,
                "sessionKey": session_key,
                "messageId":  message_id,
                "startedAt":  started_iso,
                "updatedAt":  iso_now(),
            }
            with open(tmp, "w") as f:
                json.dump(payload, f)
            os.replace(tmp, path)  # atomic

        if share_url:
            print(f"\n\n✅ published: {share_url}")
            return 0
        if stalled:
            print(f"\n\n❌ {stall_reason}")
            return 3
        time.sleep(args.interval)

if __name__ == "__main__":
    sys.exit(main() or 0)
